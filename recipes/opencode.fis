# opencode: AI coding agent, built for the terminal (anomalyco/opencode,
# formerly hosted at sst/opencode -- that name now just redirects; homepage
# opencode.ai). AUR-only, no official Arch/Artix repo. Prebuilt, not
# compiled from source -- see tools/fau/fau.md. Built via `fau build opencode`.
PKG_SRC_URL="https://github.com/anomalyco/opencode/releases/download/v1.17.15/opencode-linux-x64.tar.gz"
PKG_SRC_SHA256="0e1353771192c7d2dc0c610d61ff70668bb8a4420dc4d9e35cfd33d7245f3e67"
PKG_VERSION="1.17.15"
PKG_DESCRIPTION="AI coding agent for the terminal (opencode.ai)"
PKG_DEPENDS="glibc"
PKG_BUILD_DEPS=""
PKG_BIN="usr/bin/opencode"

recipe_source_for_version() {
	local version=$1
	echo "https://github.com/anomalyco/opencode/releases/download/v${version}/opencode-linux-x64.tar.gz"
	echo ""
}

recipe_build() {
	local src=$1 app_dir=$2 sandbox_dir=$3
	# Re-fetches/re-extracts PKG_SRC_URL itself rather than trusting $src --
	# this release asset is a flat tarball, see tools/fau/fau.md.
	local tarball; tarball=$(build_fetch_source "$PKG_SRC_URL" "$PKG_SRC_SHA256")
	mkdir -p "$app_dir/usr/bin"
	tar -xzf "$tarball" -C "$app_dir/usr/bin"
	chmod 755 "$app_dir/usr/bin/opencode"
}
