# opencode-desktop: Electron-based desktop GUI for opencode (see
# opencode.fis), same anomalyco/opencode repo/release, AUR-only. Prebuilt,
# not compiled from source -- see tools/fau/fau.md. Built via
# `fau build opencode-desktop`.
PKG_SRC_URL="https://github.com/anomalyco/opencode/releases/download/v1.17.15/opencode-desktop-linux-amd64.deb"
PKG_SRC_SHA256="8c11ad312e65a495955def8acd08114a1a3c05c684cc6bce37321b01695e774c"
PKG_VERSION="1.17.15"
PKG_DESCRIPTION="Open source AI coding agent -- desktop app (opencode.ai)"
PKG_DEPENDS="glibc,gcc-libs,glib2,nspr,nss,dbus,at-spi2-core,libcups,cairo,gtk3,pango,libx11,libxcomposite,libxdamage,libxext,libxfixes,libxrandr,mesa,expat,libxcb,libxkbcommon,alsa-lib,libnotify,libxss,libxtst,xdg-utils,util-linux-libs,libsecret"
PKG_BUILD_DEPS="xz"
PKG_BIN="usr/bin/opencode-desktop"

recipe_source_for_version() {
	local version=$1
	echo "https://github.com/anomalyco/opencode/releases/download/v${version}/opencode-desktop-linux-amd64.deb"
	echo ""
}

recipe_build() {
	local src=$1 app_dir=$2 sandbox_dir=$3

	local libdir="$app_dir/usr/lib/opencode-desktop"
	mkdir -p "$libdir"
	cp -a "$src/opt/OpenCode/." "$libdir/"

	mkdir -p "$app_dir/usr/bin"
	cat > "$app_dir/usr/bin/opencode-desktop" <<-EOF
	#!/bin/sh
	exec "$libdir/ai.opencode.desktop" --no-sandbox "\$@"
	EOF
	chmod 755 "$app_dir/usr/bin/opencode-desktop"

	local size icon_src
	for size in 32x32 64x64 128x128; do
		icon_src="$src/usr/share/icons/hicolor/$size/apps/ai.opencode.desktop.png"
		[ -f "$icon_src" ] || continue
		mkdir -p "$app_dir/usr/share/icons/hicolor/$size/apps"
		cp "$icon_src" "$app_dir/usr/share/icons/hicolor/$size/apps/opencode-desktop.png"
	done

	mkdir -p "$app_dir/usr/share/applications"
	cat > "$app_dir/usr/share/applications/opencode-desktop.desktop" <<-EOF
	[Desktop Entry]
	Name=OpenCode
	Comment=Open source AI coding agent (desktop app)
	Exec=opencode-desktop %U
	Icon=opencode-desktop
	Terminal=false
	Type=Application
	MimeType=x-scheme-handler/opencode;
	Categories=Development;
	StartupWMClass=ai.opencode.desktop
	EOF
}
